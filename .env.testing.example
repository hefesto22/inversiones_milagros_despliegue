APP_NAME=Hueveria
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ----------------------------------------------------------------
# DB de TESTING — separada de la DB de desarrollo
# Esta base de datos se destruye y recrea en cada test run.
# NUNCA apuntar a la DB de desarrollo ni a la de producción.
#
# Para setup local:
#   1. Copiar este archivo a .env.testing:   cp .env.testing.example .env.testing
#   2. Ajustar DB_USERNAME / DB_PASSWORD a tus credenciales locales
#   3. Crear la base de datos:
#        mysql -u root -p -e "CREATE DATABASE hueveria_testing CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
#   4. Generar APP_KEY:   php artisan key:generate --env=testing
# ----------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hueveria_testing
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ----------------------------------------------------------------
# Drivers en memoria / sync para tests rápidos y deterministas
# ----------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=array
CACHE_STORE=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
SESSION_LIFETIME=120

MAIL_MAILER=array

# ----------------------------------------------------------------
# Optimizaciones de tests
# ----------------------------------------------------------------
BCRYPT_ROUNDS=4
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
